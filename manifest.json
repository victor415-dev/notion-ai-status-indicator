{
	"manifest_version": 3,
	"name": "Notion AI 对话完成指示器",
	"version": "0.3.0",
	"description": "检测 Notion AI 网页版对话状态（思考/输出/完成）：页面内宠物 + 工具栏角标 + 画中画悬浮窗（置顶浮于所有应用之上，实时显示所有对话并可点击跳转） + 完成系统通知提醒。",
	"minimum_chrome_version": "116",
	"permissions": ["notifications", "storage", "offscreen"],
	"host_permissions": ["*://app.notion.com/*", "*://*.notion.so/*"],
	"icons": {
		"16": "assets/icon-16.png",
		"48": "assets/icon-48.png",
		"128": "assets/icon-128.png"
	},
	"background": {
		"service_worker": "src/background/service-worker.js",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": ["*://app.notion.com/*", "*://*.notion.so/*"],
			"run_at": "document_start",
			"world": "MAIN",
			"js": ["src/content/interceptor.js"]
		},
		{
			"matches": ["*://app.notion.com/*", "*://*.notion.so/*"],
			"run_at": "document_start",
			"world": "ISOLATED",
			"js": ["src/content/content.js"],
			"css": ["src/content/pet.css"]
		}
	],
	"action": {
		"default_title": "Notion AI 指示器",
		"default_popup": "src/popup/popup.html",
		"default_icon": {
			"16": "assets/icon-16.png",
			"48": "assets/icon-48.png",
			"128": "assets/icon-128.png"
		}
	}
}
